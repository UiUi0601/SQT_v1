# ============================================================
# AQT_v1 — 環境變數範本
# 操作步驟：cp .env.example .env  →  填入真實值  →  啟動機器人
# 警告：.env 已加入 .gitignore，請勿將真實金鑰上傳至版本控制
# ============================================================

# ── Binance API 金鑰 ─────────────────────────────────────────
# 取得方式：https://www.binance.com/zh-TW/my/settings/api-management
#
# ⚠️  安全建議（務必遵守）：
#   1. 在 Binance 後台「限制存取 IP」— 只允許本機 IP 連線
#   2. 關閉「提現」權限 — 僅需「現貨交易」+「讀取」兩項
#   3. 定期輪替金鑰（建議每 90 天更換一次）
#   4. 永遠不要將金鑰貼入程式碼、截圖或聊天室
#
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── 環境切換 ─────────────────────────────────────────────────
# true  = Testnet 測試環境（不消耗真實資金）⚗️  ← 建議先測試
# false = 正式環境（真實資金）⚠️  確認策略穩定後才切換
BINANCE_TESTNET=true

# ── 機器人行為 ────────────────────────────────────────────────
GRID_INTERVAL_SECONDS=30   # 主迴圈間隔（秒，建議 ≥10）
USE_WEBSOCKET=true          # true=WebSocket即時成交；false=REST輪詢備援
USE_BNB_FEE=false           # 是否使用 BNB 折扣手續費
DEBUG_MODE=false            # 除錯模式（詳細日誌）

# ── 風險控管 ─────────────────────────────────────────────────
MAX_EXPOSURE_PCT=0.30       # 單幣種曝險上限（佔帳戶總資金）
MAX_24H_DRAWDOWN_PCT=0.10   # 24h 滾動回撤上限（觸發自動暫停）
PAUSE_DURATION_HOURS=4.0    # 回撤觸發後暫停開倉時長（小時）

# ── 資料庫 ───────────────────────────────────────────────────
DB_PATH=trading_bot.db      # SQLite 路徑（相對於專案根目錄）

# ── Kill Switch 平倉模式 ──────────────────────────────────────
KILL_CLOSE_MODE=limit_5pct    # limit_5pct | twap | market

# ── API 斷路器 ────────────────────────────────────────────────
CB_ERROR_THRESHOLD=10         # 觸發熔斷的錯誤次數（60s 內）
CB_WINDOW_SEC=60
CB_COOLDOWN_SEC=600           # 熔斷冷卻（秒，預設 10 分鐘）

# ── 進程管理 ─────────────────────────────────────────────────
GRACEFUL_TIMEOUT=45           # start_app.py 優雅等待秒數

# ── 選填：Telegram 通知 + 心跳包 ─────────────────────────────
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# HEARTBEAT_INTERVAL_HOURS=12   # 心跳包間隔（小時，預設 12）

# ── 選填：UI 身份驗證 ─────────────────────────────────────────
# 產生密碼雜湊：python -m quant_system.utils.ui_auth hash
# UI_USERNAME=admin
# UI_PASSWORD_HASH=pbkdf2:sha256:600000$<salt>$<hash>
#
# 或存入 .streamlit/secrets.toml（推薦）：
#   [auth]
#   username      = "admin"
#   password_hash = "pbkdf2:sha256:600000$..."

# ── 選填：機密管理（Master Password 加密）────────────────────
# 使用方式：
#   1. python scripts/encrypt_env.py  → 產生 .env.enc
#   2. 啟動時：AQT_MASTER_PASSWORD=your_pwd python run_bot.py
# AQT_MASTER_PASSWORD=
